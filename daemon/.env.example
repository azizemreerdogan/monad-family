# ---- Blockchain ----
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
# Primary wallet (used when no per-agent keys are configured)
AGENT_PRIVATE_KEY=0x...
# Optional: per-agent keys, comma-separated, positionally matched to AGENT_IDS
# AGENT_PRIVATE_KEYS=0xkey1,0xkey2,0xkey3

# ---- Contracts (leave blank or set to "mock" to enable mock mode) ----
CONTRACT_AGENT_NFT=
CONTRACT_WORK_ENGINE=
CONTRACT_FAMILY_REGISTRY=
CONTRACT_MARKETPLACE=

# ---- Agents ----
AGENT_IDS=1,2,3,4,5
WORK_INTERVAL_MS=120000

# ---- Lifecycle Intervals ----
MARRIAGE_CHECK_INTERVAL_MS=300000
CHILD_CHECK_INTERVAL_MS=600000
MIN_CHILD_AGE=20
MAX_CHILDREN_PER_COUPLE=3
ENABLE_MARKETPLACE=false

# ---- AI ----
GEMINI_API_KEY=sk-ant-...

# ---- IPFS / Pinata ----
PINATA_JWT=...
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# ---- Dev ----
MOCK_MODE=false
LOG_LEVEL=info
